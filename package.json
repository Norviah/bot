{
  "name": "bot",
  "version": "1.0.0",
  "description": "A template bot for discord using Typescript and Akairo.",
  "private": true,
  "main": "./build/index.js",
  "scripts": {
    "build": "./node_modules/typescript/bin/tsc",
    "start": "node ./build/index.js",
    "lint": "./node_modules/prettier/bin-prettier.js -c src -w",
    "publish:patch": "./node_modules/standard-version/bin/cli.js --release-as patch",
    "publish:minor": "./node_modules/standard-version/bin/cli.js --release-as minor",
    "publish:major": "./node_modules/standard-version/bin/cli.js --release-as major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norviah/bot.git"
  },
  "keywords": [
    "bot",
    "discord"
  ],
  "author": "norviah",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/norviah/bot/issues"
  },
  "homepage": "https://github.com/norviah/bot#readme",
  "devDependencies": {
    "@types/app-root-path": "^1.2.4",
    "@types/moment-duration-format": "^2.2.2",
    "@types/node": "^14.11.2",
    "@types/ws": "^7.2.7",
    "@typescript-eslint/eslint-plugin": "^4.3.0",
    "@typescript-eslint/parser": "^4.3.0",
    "eslint": "^7.10.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-plugin-prettier": "^3.1.4",
    "prettier": "^2.1.2",
    "standard-version": "^9.0.0",
    "typescript": "^4.0.3"
  },
  "dependencies": {
    "@norviah/logger": "^2.0.1",
    "app-root-path": "^3.0.0",
    "better-sqlite3": "^7.1.1",
    "discord-akairo": "^8.1.0",
    "discord.js": "^12.3.1",
    "enmap": "^5.8.0",
    "spacetime": "^6.6.4"
  }
}
